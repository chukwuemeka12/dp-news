---
import type { ArticleEntry } from '../lib/content';
import {
	formatDisplayDate,
	getArticleDateEntries,
	getLocalDocumentLink,
	getPreferredArticleLink,
	getPrimaryArticleDate,
	getPrimaryArticleDateLabel,
	getSourceArticleLink,
} from '../lib/content';
import SourceBadge from './SourceBadge.astro';

interface Props {
	article: ArticleEntry;
}

const { article } = Astro.props;
const { data } = article;
const dateEntries = getArticleDateEntries(data);
const primaryDate = getPrimaryArticleDate(data);
const primaryDateLabel = getPrimaryArticleDateLabel(data);
const preferredLink = getPreferredArticleLink(data);
const sourceLink = getSourceArticleLink(data);
const localDocumentLink = getLocalDocumentLink(data);
---

<article class="article-card">
	<div class="article-meta">
		<SourceBadge source={data.source} />
		<span>{primaryDateLabel}: {formatDisplayDate(primaryDate)}</span>
		<span class="category-pill">{data.category}</span>
	</div>

	<h2>
		<a href={preferredLink} target="_blank" rel="noreferrer">
			{data.title}
		</a>
	</h2>

	<p>{data.summary}</p>

	{
		dateEntries.length > 1 && (
			<div class="date-stack">
				{dateEntries.map((entry) => (
					<div class="date-row">
						<span class="date-label">{entry.label}</span>
						<span>{formatDisplayDate(entry.date)}</span>
					</div>
				))}
			</div>
		)
	}

	<div class="article-footer">
		<div class="tag-row">
			{data.tags.slice(0, 4).map((tag) => <span class="tag-chip">{tag}</span>)}
		</div>
		<div class="tag-row">
			{
				localDocumentLink && (
					<a class="article-link" href={localDocumentLink} target="_blank" rel="noreferrer">Read local PDF</a>
				)
			}
			<a class="article-link" href={sourceLink} target="_blank" rel="noreferrer">Read source</a>
		</div>
	</div>
</article>
