---
import ArticleCard from '../components/ArticleCard.astro';
import Base from '../layouts/Base.astro';
import { getArticlesByCategory, getStatusSnapshot } from '../lib/content';

const guidance = await getArticlesByCategory('guidance');
const status = await getStatusSnapshot();
---

<Base
	title="DPA News | Guidance"
	description="Recent guidance, publications, and regulator commentary tracked by DPA News."
>
	<section class="hero-card">
		<div class="hero-copy">
			<p class="eyebrow">Guidance</p>
			<h2>Fresh guidance from regulators and privacy institutions.</h2>
			<p>
				The guidance stream surfaces official publications, practical resources, and advisory material from the
				curated source list.
			</p>
		</div>

		<div class="stats-grid">
			<div class="stat-card">
				<span class="stat-label">Guidance items</span>
				<span class="stat-value">{status?.totals.byCategory.guidance ?? 0}</span>
			</div>
		</div>
	</section>

	<section>
		<div class="section-header">
			<div>
				<h2 class="section-title">Guidance feed</h2>
				<p class="section-subtitle">Official publications, statements, and resources.</p>
			</div>
		</div>

		{
			guidance.length > 0 ? (
				<div class="article-grid">
					{guidance.map((article) => <ArticleCard article={article} />)}
				</div>
			) : (
				<div class="empty-state">
					<p>No guidance items are available yet.</p>
				</div>
			)
		}
	</section>
</Base>
