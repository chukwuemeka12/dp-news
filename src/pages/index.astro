---
import ArticleCard from '../components/ArticleCard.astro';
import Base from '../layouts/Base.astro';
import { formatTimestamp, getSortedArticles, getStatusSnapshot, isSourceFresh } from '../lib/content';

const articles = await getSortedArticles();
const latestArticles = articles.slice(0, 20);
const status = await getStatusSnapshot();
const freshSources = status?.sources.filter((source) => isSourceFresh(source)).length ?? 0;
---

<Base
	title="DPA News | Global data protection developments"
	description="A low-maintenance aggregation site tracking global data protection decisions, guidance, and public regulatory developments."
>
	<section class="hero-card">
		<div class="hero-copy">
			<p class="eyebrow">MVP coverage</p>
			<h2>Global data protection intelligence without a manual newsroom.</h2>
			<p>
				DPA News monitors curated public feeds and structured trackers so the profession can spot major regulatory
				moves, new guidance, and notable enforcement developments in one place.
			</p>
		</div>

		<div class="stats-grid">
			<div class="stat-card">
				<span class="stat-label">Articles in retention window</span>
				<span class="stat-value">{status?.totals.articles ?? 0}</span>
			</div>
			<div class="stat-card">
				<span class="stat-label">Healthy sources</span>
				<span class="stat-value">{freshSources}/{status?.totals.totalSources ?? 0}</span>
			</div>
			<div class="stat-card">
				<span class="stat-label">Last pipeline run</span>
				<p>{formatTimestamp(status?.generatedAt ?? null)}</p>
			</div>
		</div>
	</section>

	<section>
		<div class="section-header">
			<div>
				<h2 class="section-title">Latest coverage</h2>
				<p class="section-subtitle">Newest items across the current curated source set.</p>
			</div>
		</div>

		{
			latestArticles.length > 0 ? (
				<div class="article-grid">
					{latestArticles.map((article) => <ArticleCard article={article} />)}
				</div>
			) : (
				<div class="empty-state">
					<p>No articles have been fetched yet. Run the ingestion scripts to populate the first snapshot.</p>
				</div>
			)
		}
	</section>
</Base>
